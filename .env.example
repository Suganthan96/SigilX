OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# X Layer — use testnet values during dev, swap for mainnet before launch
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_RPC_TESTNET=https://testrpc.xlayer.tech/terigon
XLAYER_RPC_MAINNET=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=1952
XLAYER_PRIVATE_KEY=your_deployer_private_key_here

# Minter wallet (the SigilX API service's signing wallet, authorized in contract)
MINTER_ADDRESS=your_minter_wallet_address_here

# Deployed contract addresses (filled in after `npm run deploy:testnet / deploy:mainnet`)
CHAIN_PORTRAIT_ADDRESS_TESTNET=
CHAIN_PORTRAIT_ADDRESS_MAINNET=

# OKX Payment / Agentic Wallet
PAYMENT_WALLET=your_agentic_wallet_address
PAYMENT_SECRET=your_x402_payment_secret

# Mint fee for mainnet deploy (in OKB, e.g. "0.005")
MINT_FEE_OKB=0.005

# Safety confirm for mainnet deploy script (must be exactly "DEPLOY_TO_MAINNET")
# MAINNET_DEPLOY_CONFIRM=DEPLOY_TO_MAINNET

# OKLink explorer API key (for contract verification)
XLAYER_EXPLORER_API_KEY=your_oklink_api_key_here

# Service config
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_BASE_URL=https://your-domain.com
MCP_PORT=8001

# Cache (optional Redis; defaults to in-memory if not set)
# REDIS_URL=redis://localhost:6379
PORTRAIT_CACHE_TTL=86400

# Demo mode: bypass x402 for judge testing (set to "true" only for demo)
DEMO_MODE=false
DEMO_API_KEY=set_a_random_string_for_judge_access
