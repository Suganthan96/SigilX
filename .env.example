OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# X Layer — use testnet values during dev, swap for mainnet before launch
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_RPC_TESTNET=https://testrpc.xlayer.tech/terigon
XLAYER_RPC_MAINNET=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=1952
XLAYER_PRIVATE_KEY=your_deployer_private_key_here

# Optional: a separate key used ONLY for signing the X Layer mainnet deploy
# transaction (`npm run deploy:mainnet` / hardhat.config.js's "xlayer-mainnet"
# network). Falls back to XLAYER_PRIVATE_KEY if unset. Useful for keeping a
# fresh deploy-only wallet's key out of the shared testnet/runtime key.
XLAYER_PRIVATE_KEY_MAINNET=

# Minter wallet (the SigilX API service's signing wallet, authorized in contract)
MINTER_ADDRESS=your_minter_wallet_address_here

# Deployed contract addresses (filled in after `npm run deploy:testnet / deploy:mainnet`)
CHAIN_PORTRAIT_ADDRESS_TESTNET=
CHAIN_PORTRAIT_ADDRESS_MAINNET=

# OKX Payment / Agentic Wallet
PAYMENT_WALLET=your_agentic_wallet_address
PAYMENT_SECRET=your_x402_payment_secret

# x402 self-hosted facilitator (services/api/facilitator.py): SigilX verifies
# and settles payments itself rather than depending on OKX's undocumented
# Broker service. X402_ASSET is a deployed, EIP-3009-compatible token address.
#
# Testnet: use contracts/src/PaymentToken.sol (18 decimals) via
#   `npm run deploy:payment-token:testnet`.
# Mainnet: use X Layer's real USD₮0 (6 decimals) at
#   0x779ded0c9e1022225f8e0630b35a9b54be713736 — verified on-chain to support
#   transferWithAuthorization with EIP-712 domain {name: "USD₮0", version: "1"}.
X402_ASSET=
X402_ASSET_DECIMALS=18
X402_TOKEN_NAME=SigilX Test USD
X402_TOKEN_VERSION=1
X402_NETWORK=eip155:1952

# Price per /generate call, in SERVICE_PRICE's human units of X402_ASSET
# (e.g. "0.10" = 10 cents at X402_ASSET_DECIMALS). "0" lists the service free
# and fully bypasses the x402 payment gate — used during OKX marketplace review.
SERVICE_PRICE=0

# Mint fee for mainnet deploy (in OKB, e.g. "0.005")
MINT_FEE_OKB=0.005

# Safety confirm for mainnet deploy script (must be exactly "DEPLOY_TO_MAINNET")
# MAINNET_DEPLOY_CONFIRM=DEPLOY_TO_MAINNET

# OKLink explorer API key (for contract verification)
XLAYER_EXPLORER_API_KEY=your_oklink_api_key_here

# Pinata (IPFS pinning) — used to host portrait SVGs at a real https:// URL so
# explorers/marketplaces that don't render inline data URIs (e.g. OKLink) can
# display the image. tokenURI() falls back to the on-chain data URI if unset.
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Service config
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_BASE_URL=https://your-domain.com
MCP_PORT=8001

# Cache (optional Redis; defaults to in-memory if not set)
# REDIS_URL=redis://localhost:6379
PORTRAIT_CACHE_TTL=86400

# Demo mode: bypass x402 for judge testing (set to "true" only for demo)
DEMO_MODE=false
DEMO_API_KEY=set_a_random_string_for_judge_access
